		"vue": "^3.5.29",
		"vue-router": "^5.0.3"
	},
	"devDependencies": {
		"@rushstack/eslint-patch": "^1.16.1",
		"@types/node": "^25.3.3",
		"@types/bootstrap": "^5.2.10",
		"@vitejs/plugin-vue": "^6.0.4",
		"@vue/eslint-config-prettier": "^10.2.0",
		"@vue/eslint-config-typescript": "^14.7.0",
		"@vue/tsconfig": "^0.9.0",
		"eslint": "^10.0.2",
		"eslint-plugin-vue": "^10.8.0",
		"npm-run-all2": "^8.0.4",
		"prettier": "^3.8.1",
		"sass": "1.97.3",
		"typescript": "^5.9.3",
